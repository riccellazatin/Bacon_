# Django Settings
DEBUG=false
SECRET_KEY=your-super-secret-key-change-this-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,bacon-backend.onrender.com
RENDER_EXTERNAL_HOSTNAME=bacon-backend.onrender.com

# Database (PostgreSQL via pgAdmin or Render Managed DB)
DATABASE_URL=postgresql://user:password@hostname:5432/bacon

# CORS Configuration - Frontend domain(s)
CORS_ALLOWED_ORIGINS=https://yourdomain.vercel.app,http://localhost:3000

# Google OAuth (get from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_REDIRECT_URI=https://yourdomain.vercel.app/api/accounts/google/callback/

# Gemini API (for task prioritization)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=10

# PayPal (for shop functionality)
PAYPAL_CLIENT_ID=your-paypal-client-id-here
PAYPAL_SECRET_KEY=your-paypal-secret-key-here
