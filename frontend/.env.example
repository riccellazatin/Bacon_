# Frontend Environment Variables
# Add these to Vercel Environment Variables in deployment settings

# Backend API URL - Update to your Render backend production URL
REACT_APP_API_BASE=https://bacon-backend.onrender.com/api

# Google OAuth
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id-here
REACT_APP_GOOGLE_REDIRECT_URI=https://yourdomain.vercel.app/api/accounts/google/callback/

# PayPal
REACT_APP_PAYPAL_CLIENT_ID=your-paypal-client-id-here

